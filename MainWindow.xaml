<Window x:Class="PCMonitor.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Width="250" Height="300" WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent" Topmost="True" ShowInTaskbar="True" WindowStartupLocation="CenterScreen">
    <Border Background="#CC111111" CornerRadius="14" Padding="12" BorderBrush="#33FFFFFF" BorderThickness="1">
        <StackPanel>
            <!-- HEADER -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="PC MONITOR" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button x:Name="CloseButton" Grid.Column="1" Width="22" Height="22" Content="✕" FontSize="11" FontWeight="Bold" Cursor="Hand" Click="CloseButton_Click" Margin="4,0,0,0" ToolTip="Закрыть">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#AAFFFFFF"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#88FF4444"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#AAFF4444"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#CCFF2222"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFF2222"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            <!-- CPU -->
            <TextBlock Text="CPU" Foreground="#00FF99" FontSize="15" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock x:Name="CpuNameText" Foreground="#88FFFFFF" FontSize="12" Margin="0,0,6,0"/>
                <TextBlock x:Name="CpuSpecsText" Foreground="#66FFFFFF" FontSize="10"/>
            </StackPanel>
            <TextBlock x:Name="CpuTempText" Foreground="White" FontSize="12"/>
            <ProgressBar x:Name="CpuLoadBar" Height="12" Maximum="100" Margin="0,4,0,0"/>
            <TextBlock x:Name="CpuLoadText" Foreground="White" FontSize="11" Margin="0,2,0,8"/>
            <!-- GPU -->
            <TextBlock Text="GPU" Foreground="#00BFFF" FontSize="15" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock x:Name="GpuNameText" Foreground="#88FFFFFF" FontSize="12" Margin="0,0,6,0"/>
                <TextBlock x:Name="GpuSpecsText" Foreground="#66FFFFFF" FontSize="10"/>
            </StackPanel>
            <TextBlock x:Name="GpuTempText" Foreground="White" FontSize="12"/>
            <ProgressBar x:Name="GpuLoadBar" Height="12" Maximum="100" Margin="0,4,0,0"/>
            <TextBlock x:Name="GpuLoadText" Foreground="White" FontSize="11" Margin="0,2,0,0"/>
            <TextBlock x:Name="GpuFanText" Foreground="#FFA500" FontSize="11" Margin="0,2,0,8"/>
            <!-- RAM -->
            <TextBlock x:Name="RamText" Foreground="#FFD700" FontSize="12"/>
        </StackPanel>
    </Border>
</Window>